{
  "name": "docs-rag-mcp",
  "version": "0.1.0",
  "description": "MCP server that ingests local docs (and optional URLs), indexes them with lexical + optional vector embeddings, and returns the most relevant chunks with citations — so an agent grounds answers in real docs instead of hallucinating APIs.",
  "type": "module",
  "bin": {
    "docs-rag-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rag",
    "retrieval",
    "embeddings",
    "documentation",
    "grounding"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}

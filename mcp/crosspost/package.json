{
  "name": "crosspost-mcp",
  "version": "0.2.0",
  "description": "MCP server that takes one message (e.g. an AI update you share on Slack), cleans Slack markdown, and cross-posts it formatted per platform: X as a weighted 280-char thread, LinkedIn as a single long-form post. Preview-first; publishes only on explicit confirmation. Shares social-core (bundled into dist at build).",
  "type": "module",
  "bin": {
    "crosspost-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:zod",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "crosspost",
    "x",
    "twitter",
    "linkedin",
    "slack",
    "social"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "social-core": "*",
    "esbuild": "^0.24.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}

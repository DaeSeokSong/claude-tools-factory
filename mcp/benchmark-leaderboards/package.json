{
  "name": "benchmark-leaderboards-mcp",
  "version": "0.1.0",
  "description": "MCP server that maps an AI/ML benchmark dataset to its authoritative leaderboard (official vs community-standard vs fragmented vs archived) and fetches current rankings where a live API exists.",
  "type": "module",
  "bin": {
    "benchmark-leaderboards-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "benchmark",
    "leaderboard",
    "sota",
    "machine-learning"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}

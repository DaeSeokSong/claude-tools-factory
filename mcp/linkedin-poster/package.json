{
  "name": "linkedin-poster-mcp",
  "version": "0.1.0",
  "description": "MCP server to post to LinkedIn: preview a single long-form post (<=3000 chars, see-more hint, hashtag advice) and publish only on explicit confirmation. Shares social-core (bundled into dist at build).",
  "type": "module",
  "bin": {
    "linkedin-poster-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:zod",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "linkedin",
    "posting",
    "social"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "social-core": "*",
    "esbuild": "^0.24.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}

# Dependencies
node_modules/
.pnp
.pnp.*

# Lockfiles — deps are pinned in each package.json; locks regenerate on install
package-lock.json
yarn.lock
pnpm-lock.yaml

# Builds
dist/
build/
out/
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Env / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Claude Code local overrides
.claude/settings.local.json

# Scratch / temporary experiments — run in-repo, never committed; delete freely
.scratch/
.evolve/

# Vector embedding sidecar caches (regenerable via the experience-ledger embed_backfill tool)
*.vec.jsonl

# docs-rag index cache (regenerable via the docs-rag ingest_docs tool)
.docs-rag/
